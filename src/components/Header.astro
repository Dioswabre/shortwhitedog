---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="site-title">Shortwhitedog</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Photos</HeaderLink>
			<HeaderLink href="/about">About Caio</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 2em;
		background-color: var(--cream);
		border-bottom: 1px solid var(--cream-dark);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 900px;
		margin: 0 auto;
		padding: 1.2em 0;
	}

	.site-title {
		font-family: var(--font-heading);
		font-size: 1.4em;
		font-weight: 700;
		color: var(--slate);
		text-decoration: none;
		letter-spacing: -0.01em;
	}

	.site-title:hover {
		color: var(--green);
	}

	.internal-links {
		display: flex;
		gap: 0.5em;
	}

	.internal-links a {
		font-family: var(--font-body);
		font-size: 0.95em;
		padding: 0.4em 0.8em;
		color: var(--slate-light);
		text-decoration: none;
		border-radius: 4px;
		transition: color 0.2s ease, background-color 0.2s ease;
	}

	.internal-links a:hover,
	.internal-links a.active {
		color: var(--slate);
		background-color: var(--cream-dark);
	}

	@media (max-width: 720px) {
		header {
			padding: 0 1em;
		}
	}
</style>