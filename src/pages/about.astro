---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Play Misty for me — Shortwhitedog" description="Caio the Sealyham Terrier" />
	</head>
	<body>
		<div class="hero-wrap">
			<div class="hero-header">
				<a href="/" class="hero-logo" aria-label="Shortwhitedog home">
					<img src="/caio-logo.png" alt="Shortwhitedog" width="56" height="56" />
				</a>
				<nav class="hero-nav">
					<a href="/blog">I hate Hector</a>
					<a href="/about">Play Misty for me</a>
				</nav>
			</div>
			<video class="hero-video" autoplay muted loop playsinline preload="auto">
				<source src="/Caio-video-small.mp4" type="video/mp4" />
			</video>
			<div class="hero-text">
				<h1>Play Misty for me</h1>
				<p class="tagline">Sniff me baby.</p>
			</div>
		</div>

		<section class="photo-spread">
			<div class="polaroid tilt-left">
				<img src="/Caio-car2.jpg" alt="Caio at the wheel" />
				<p class="polaroid-caption">I drove all night</p>
			</div>
			<div class="polaroid tilt-right">
				<img src="/Handsome-boy.jpg" alt="Handsome boy" />
				<p class="polaroid-caption">Handsome boy</p>
			</div>
		</section>

		<div class="signature-illustration">
			<img src="/Caio-illustration.png" alt="Caio" />
		</div>

		<Footer />
	</body>
</html>

<style is:global>
	body {
		margin: 0;
		padding: 0;
		background-color: #faf7f2;
		font-family: 'Lato', system-ui, sans-serif;
	}

	.hero-wrap {
		position: relative;
		width: 100%;
		height: 100vh;
		overflow: hidden;
	}

	.hero-video {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
		display: block;
	}

	.hero-wrap::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to bottom,
			rgba(0,0,0,0.2) 0%,
			rgba(0,0,0,0) 30%,
			rgba(0,0,0,0) 50%,
			rgba(0,0,0,0.6) 100%
		);
		pointer-events: none;
	}

	.hero-header {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		z-index: 10;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.8em 3em;
	}

	.hero-logo {
		display: flex;
		align-items: center;
		opacity: 0.6;
		transition: opacity 0.2s ease;
	}

	.hero-logo:hover {
		opacity: 0.9;
	}

	.hero-logo img {
		display: block;
		border-radius: 0;
		filter: drop-shadow(0 1px 4px rgba(0,0,0,0.3));
	}

	.hero-nav {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 2em;
	}

	.hero-nav a {
		font-family: 'Lato', system-ui, sans-serif;
		font-size: 0.95em;
		color: white !important;
		text-decoration: none !important;
		text-shadow: 0 1px 4px rgba(0,0,0,0.3);
		transition: opacity 0.2s ease;
		white-space: nowrap;
	}

	.hero-nav a:hover {
		opacity: 0.75;
	}

	.hero-text {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		z-index: 10;
		padding: 3em;
	}

	.hero-text h1 {
		font-family: 'Fraunces', Georgia, serif;
		font-size: clamp(2.8em, 8vw, 7em);
		font-weight: 700;
		color: white;
		margin: 0 0 0.15em 0;
		line-height: 0.95;
		letter-spacing: -0.02em;
		text-shadow: 0 2px 20px rgba(0,0,0,0.25);
	}

	.tagline {
		font-family: 'Fraunces', Georgia, serif;
		font-style: italic;
		font-size: clamp(0.95em, 2.5vw, 1.4em);
		color: rgba(255,255,255,0.85);
		margin: 0;
		text-shadow: 0 1px 8px rgba(0,0,0,0.3);
	}

	.photo-spread {
		padding: 6em 4em 4em 4em;
		display: flex;
		align-items: flex-start;
		justify-content: center;
		gap: 6em;
	}

	.polaroid {
		background: #ffffff;
		padding: 1em 1em 3.5em 1em;
		box-shadow: 4px 6px 24px rgba(44,58,71,0.13), 0 1px 3px rgba(44,58,71,0.06);
		width: 32%;
		flex-shrink: 0;
	}

	.polaroid img {
		width: 100%;
		height: auto;
		display: block;
		border-radius: 0;
		max-width: none;
	}

	.polaroid-caption {
		font-family: 'Caveat', cursive;
		font-size: 1.2em;
		color: #4a5568;
		text-align: center;
		margin: 0.8em 0 0 0;
		padding: 0;
	}

	.polaroid.tilt-left {
		transform: rotate(-2.5deg);
		margin-top: 2.5em;
	}

	.polaroid.tilt-right {
		transform: rotate(1.8deg);
	}

	.signature-illustration {
		padding: 3em 3em 0 3em;
		display: flex;
		justify-content: center;
	}

	.signature-illustration img {
		width: 140px;
		height: auto;
		display: block;
		mix-blend-mode: multiply;
		opacity: 0.85;
	}

	@media (max-width: 600px) {
		.hero-wrap {
			height: 70vh;
		}

		.hero-header {
			padding: 1.2em 1.5em;
		}

		.hero-nav {
			gap: 1.2em;
		}

		.hero-nav a {
			font-size: 0.85em;
		}

		.hero-text {
			padding: 1.5em;
		}

		.hero-text h1 {
			font-size: 2.4em;
		}

		.tagline {
			font-size: 0.95em;
			margin-top: 0.4em;
		}

		.photo-spread {
			padding: 3em 2em;
			gap: 2em;
			flex-direction: column;
			align-items: center;
		}

		.polaroid {
			width: 80%;
		}

		.polaroid.tilt-left,
		.polaroid.tilt-right {
			margin-top: 0;
		}

		.signature-illustration {
			padding: 2em 1.5em 0 1.5em;
		}

		.signature-illustration img {
			width: 100px;
		}
	}
</style>