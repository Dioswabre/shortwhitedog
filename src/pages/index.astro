---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Shortwhitedog" description="Caio the Sealyham Terrier" />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Shortwhitedog</h1>
				<p class="tagline">A Sealyham terrier. In Wales. Living his best life.</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	:global(body) {
		background-color: #faf7f2;
		min-height: 100vh;
	}

	main {
		max-width: 100%;
		padding: 0;
		margin: 0;
	}

	.hero {
		min-height: 70vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		padding: 4em 2em;
		background-color: var(--cream);
	}

	.hero h1 {
		font-size: 5em;
		font-family: var(--font-heading);
		font-weight: 700;
		color: var(--slate);
		margin-bottom: 0.3em;
		line-height: 1;
	}

	.tagline {
		font-family: var(--font-heading);
		font-style: italic;
		font-size: 1.4em;
		color: var(--slate-light);
		margin: 0;
	}
</style>