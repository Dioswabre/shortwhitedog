---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Shortwhitedog" description="Caio the Sealyham Terrier" />
	</head>
	<body>
		<Header />
		<div class="hero-image">
			<img src="/Caio.png" alt="Caio the Sealyham Terrier" />
		</div>
		<main>
			<section class="hero-text">
				<h1>Shortwhitedog</h1>
				<p class="tagline">A Sealyham terrier. In Wales. Living his best life.</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	:global(body) {
		background-color: #faf7f2;
		min-height: 100vh;
	}

	:global(.hero-image) {
		width: 100%;
		height: 70vh;
		overflow: hidden;
	}

	:global(.hero-image img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
		display: block;
	}

	main {
		max-width: 100%;
		padding: 0;
		margin: 0;
	}

	.hero-text {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		padding: 3em 2em;
	}

	.hero-text h1 {
		font-size: 5em;
		font-family: var(--font-heading);
		font-weight: 700;
		color: var(--slate);
		margin-bottom: 0.3em;
		line-height: 1;
	}

	.tagline {
		font-family: var(--font-heading);
		font-style: italic;
		font-size: 1.4em;
		color: var(--slate-light);
		margin: 0;
	}

	@media (max-width: 720px) {
		:global(.hero-image) {
			height: 50vh;
		}

		.hero-text h1 {
			font-size: 3em;
		}
	}
</style>