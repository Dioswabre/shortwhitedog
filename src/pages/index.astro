---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Shortwhitedog" description="Caio the Sealyham Terrier" />
	</head>
	<body>
		<div class="hero-wrap">
			<div class="hero-header">
				<a href="/" class="hero-logo" aria-label="Shortwhitedog home">
					<img src="/caio-logo.png" alt="Shortwhitedog" width="56" height="56" />
				</a>
				<nav class="hero-nav">
					<a href="/blog">I hate Hector</a>
					<a href="/about">Play Misty for me</a>
				</nav>
			</div>
			<img class="hero-img" src="/Caio.png" alt="Caio the Sealyham Terrier" />
			<div class="hero-text">
				<h1>Shortwhitedog</h1>
				<p class="tagline">The ball won't get itself, Lynne.</p>
			</div>
		</div>

		<section class="definition">
			<div class="definition-inner">
				<p class="def-entry">
					<span class="def-term">Sealyham terrier</span>
					<span class="def-phonetic">/ˈsiːləm ˈtɛrɪə/</span>
					<span class="def-partsofspeech">n.</span>
				</p>
				<p class="def-text">
					<span class="def-syn">(syn.</span> West Walian dawdling terrier, Niejo, Bandiejo, Gary<span class="def-syn">)</span>. A short, white dog.
				</p>
			</div>
		</section>

		<div class="signature-illustration">
			<img src="/Caio-illustration.png" alt="Caio" />
		</div>

		<Footer />
	</body>
</html>