---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Shortwhitedog" description="Caio the Sealyham Terrier" />
	</head>
	<body>
		<div class="hero-wrap">
			<div class="hero-header">
				<a href="/" class="hero-logo" aria-label="Shortwhitedog home">
					<img src="/caio-logo.png" alt="Shortwhitedog" width="56" height="56" />
				</a>
				<nav class="hero-nav">
					<a href="/blog">I hate Hector</a>
					<a href="/about">Play Misty for me</a>
				</nav>
			</div>
			<img class="hero-img" src="/Caio.png" alt="Caio the Sealyham Terrier" />
			<div class="hero-text">
				<h1>Shortwhitedog</h1>
				<p class="tagline">The ball won't get itself, Lynne.</p>
			</div>
		</div>

		<section class="definition">
			<div class="definition-inner">
				<p class="def-entry">
					<span class="def-term">Sealyham terrier</span>
					<span class="def-phonetic">/ˈsiːləm ˈtɛrɪə/</span>
					<span class="def-partsofspeech">n.</span>
				</p>
				<p class="def-text">
					<span class="def-syn">(syn.</span> West Walian dawdling terrier, Niejo, Bandiejo, Gary<span class="def-syn">)</span>. A short, white dog.
				</p>
			</div>
		</section>

		<Footer />
	</body>
</html>

<style is:global>
	body {
		margin: 0;
		padding: 0;
		background-color: #faf7f2;
		font-family: 'Lato', system-ui, sans-serif;
	}

	.hero-wrap {
		position: relative;
		width: 100%;
		height: 100vh;
		overflow: hidden;
	}

	.hero-img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 30%;
		display: block;
		border-radius: 0;
		max-width: none;
	}

	.hero-wrap::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to bottom,
			rgba(0,0,0,0.25) 0%,
			rgba(0,0,0,0) 30%,
			rgba(0,0,0,0) 50%,
			rgba(0,0,0,0.65) 100%
		);
		pointer-events: none;
	}

	.hero-header {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		z-index: 10;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.8em 3em;
	}

	.hero-logo {
		display: flex;
		align-items: center;
		opacity: 0.6;
		transition: opacity 0.2s ease;
	}

	.hero-logo:hover {
		opacity: 0.9;
	}

	.hero-logo img {
		display: block;
		border-radius: 0;
		filter: drop-shadow(0 1px 4px rgba(0,0,0,0.3));
	}

	.hero-nav {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 2em;
	}

	.hero-nav a {
		font-family: 'Lato', system-ui, sans-serif;
		font-size: 0.95em;
		color: white !important;
		text-decoration: none !important;
		text-shadow: 0 1px 4px rgba(0,0,0,0.3);
		transition: opacity 0.2s ease;
		white-space: nowrap;
	}

	.hero-nav a:hover {
		opacity: 0.75;
	}

	.hero-text {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		z-index: 10;
		padding: 3em;
	}

	.hero-text h1 {
		font-family: 'Fraunces', Georgia, serif;
		font-size: clamp(2.8em, 8vw, 7em);
		font-weight: 700;
		color: white;
		margin: 0 0 0.15em 0;
		line-height: 0.95;
		letter-spacing: -0.02em;
		text-shadow: 0 2px 20px rgba(0,0,0,0.25);
	}

	.tagline {
		font-family: 'Fraunces', Georgia, serif;
		font-style: italic;
		font-size: clamp(0.95em, 2.5vw, 1.4em);
		color: rgba(255,255,255,0.85);
		margin: 0;
		text-shadow: 0 1px 8px rgba(0,0,0,0.3);
	}

	.definition {
		padding: 3.5em 3em;
		background-color: #faf7f2;
	}

	.definition-inner {
		max-width: 700px;
		margin: 0;
		border-left: 3px solid #2c3a47;
		padding-left: 1.5em;
	}

	.def-entry {
		margin: 0 0 0.3em 0;
		line-height: 1.4;
	}

	.def-term {
		font-family: 'Fraunces', Georgia, serif;
		font-size: 1.4em;
		font-weight: 700;
		color: #2c3a47;
		margin-right: 0.3em;
	}

	.def-phonetic {
		font-family: 'Fraunces', Georgia, serif;
		font-style: italic;
		font-size: 0.9em;
		color: #4a5568;
		margin-right: 0.3em;
	}

	.def-partsofspeech {
		font-family: 'Lato', system-ui, sans-serif;
		font-size: 0.85em;
		font-style: italic;
		color: #4a5568;
	}

	.def-text {
		font-family: 'Fraunces', Georgia, serif;
		font-size: 1em;
		color: #2c3a47;
		line-height: 1.7;
		margin: 0;
	}

	.def-syn {
		font-style: italic;
		color: #4a5568;
	}

	@media (max-width: 600px) {
		.hero-wrap {
			height: 70vh;
		}

		.hero-header {
			padding: 1.2em 1.5em;
		}

		.hero-nav {
			gap: 1.2em;
		}

		.hero-nav a {
			font-size: 0.85em;
		}

		.hero-text {
			padding: 1.5em;
		}

		.hero-text h1 {
			font-size: 2.4em;
		}

		.tagline {
			font-size: 0.95em;
			margin-top: 0.4em;
		}

		.definition {
			padding: 2.5em 1.5em;
		}

		.def-term {
			font-size: 1.2em;
		}
	}
</style>