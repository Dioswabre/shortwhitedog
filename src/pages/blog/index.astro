---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="I hate Hector — Shortwhitedog" description="Caio the Sealyham Terrier" />
	</head>
	<body>
		<div class="hero-wrap">
			<div class="hero-header">
				<a href="/" class="hero-logo" aria-label="Shortwhitedog home">
					<img src="/caio-logo.png" alt="Shortwhitedog" width="56" height="56" />
				</a>
				<nav class="hero-nav">
					<a href="/blog">I hate Hector</a>
					<a href="/about">Play Misty for me</a>
				</nav>
			</div>
			<img class="hero-img" src="/Tiny-Cai.jpg" alt="Caio as a puppy" />
			<div class="hero-text">
				<h1>I hate Hector</h1>
				<p class="tagline">I will throw the book at you.</p>
			</div>
		</div>

		<section class="taped-section">
			<div class="taped-photo wide tilt-left">
				<div class="tape tape-tl"></div>
				<div class="tape tape-tr"></div>
				<img src="/Wild-boy.jpg" alt="Wild boy" />
			</div>
			<div class="taped-photo square tilt-right">
				<div class="tape tape-tl"></div>
				<div class="tape tape-br"></div>
				<img src="/Black-and-white.jpg" alt="Caio in black and white" />
			</div>
		</section>

		<div class="signature-illustration">
			<img src="/Caio-illustration.png" alt="Caio" />
		</div>

		<Footer />
	</body>
</html>